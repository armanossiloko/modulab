# All lab web stacks — hostname → host port on :80 via Caddy (host network).
# Domain: LOCAL_DOMAIN from .env.caddy (match PIHOLE_LOCAL_DOMAIN in .env.pihole).
# Keep labels in sync with pihole/dns-hosts.conf. Postgres is not HTTP-proxied.

{
	auto_https off
}

jellyfin.{$LOCAL_DOMAIN} {
	reverse_proxy 127.0.0.1:8096
}

