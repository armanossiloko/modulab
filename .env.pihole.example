# https://docs.pi-hole.net/docker/configuration/
# cp .env.pihole.example .env.pihole

PIHOLE_PASSWORD=change-me
TZ=Europe/Berlin
# Upstream resolvers (semicolon-separated — do not shell-source this file)
PIHOLE_UPSTREAM_DNS=1.1.1.1;1.0.0.1

# LAN IP of the Docker host (Pi-hole A records point here)
LAB_HOST_IP=192.168.0.10
PIHOLE_LOCAL_DOMAIN=network.lan

# Pin a release tag — https://hub.docker.com/r/pihole/pihole/tags
PIHOLE_TAG=latest
