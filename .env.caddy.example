# cp .env.caddy.example .env.caddy

# Dashboard — http://127.0.0.1:HOME_PORT (works without Pi-hole or port 80)
HOME_PORT=8888

# UPSTREAM_HOST for LAN proxy backends (host.docker.internal on Docker Desktop)
UPSTREAM_HOST=host.docker.internal

# network.lan reverse proxy on port 80 — set true only if you use Pi-hole DNS
ENABLE_LAN_PROXY=false
PIHOLE_LOCAL_DOMAIN=network.lan

# Pin a release tag — https://hub.docker.com/_/caddy/tags
CADDY_TAG=2-alpine
