# https://docs.n8n.io/hosting/configuration/environment-variables/
# Match PIHOLE_LOCAL_DOMAIN in .env.pihole / .env.caddy
N8N_HOST=n8n.network.lan
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
WEBHOOK_URL=http://n8n.network.lan/
GENERIC_TIMEZONE=UTC

# Optional TLS:
# DOMAIN_NAME=example.com
# SUBDOMAIN=n8n
# SSL_EMAIL=
