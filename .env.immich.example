# https://docs.immich.app/install/environment-variables
# cp .env.immich.example .env.immich

# Host paths (relative to repo root; created on first up)
UPLOAD_LOCATION=./data/immich/library
DB_DATA_LOCATION=./data/immich/postgres

# Pin a release tag, e.g. v2.1.0 — https://github.com/immich-app/immich/releases
IMMICH_VERSION=v2

# A-Za-z0-9 only (Docker env parsing)
DB_PASSWORD=immich

# Optional: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=Etc/UTC

###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
